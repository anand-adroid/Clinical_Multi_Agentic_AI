# =========================================================
#  Clinical Agentic AI — environment configuration
# =========================================================
# Copy this file to .env and fill in the values for your environment.
# Every value can also be set via Kubernetes ConfigMap / Secret in
# production — pydantic-settings reads env vars first.

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# When ANTHROPIC_API_KEY is set, code generation goes through Claude.
# When it is unset, the pipeline pauses at the code-generation phase and
# escalates to a manual-code-entry HITL gate — there is no hardcoded
# fallback library by design (see Phase 4 in docs/design_document.md).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local SQLite + on-disk checkpoints by default. In production swap DB_URL
# for managed Postgres and point the storage dirs at a shared volume or S3.
DB_URL=sqlite:///./storage/agentic.db
CHECKPOINT_DIR=./storage/checkpoints
RUN_ARTIFACT_DIR=./storage/runs
MEMORY_DIR=./storage/memory
LOG_DIR=./storage/logs

# -----------------------------------------------------------------------------
# Guardrails
# -----------------------------------------------------------------------------
MAX_REFINE_RETRIES=3
MAX_RUNTIME_SECONDS=120
ALLOW_NETWORK_IN_SANDBOX=false

# Code-preapproval gate. When true, every generated derivation pauses for
# human review before execution (cautious mode). When false (default), only
# derivations the planner flags as require_preapproval pause — typically
# regulatory_critical columns or those with LLM confidence below the
# threshold below.
REQUIRE_CODE_PREAPPROVAL=false
MIN_CONFIDENCE_THRESHOLD=0.7
PREAPPROVAL_PREVIEW_ROWS=3

# -----------------------------------------------------------------------------
# Scalability
# -----------------------------------------------------------------------------
# Single-threaded execution by default for deterministic event ordering
# in the audit log. Flip PARALLEL_EXECUTOR=true for large datasets where
# wall-clock dominates and same-DAG-level derivations are independent.
PARALLEL_EXECUTOR=false
PARALLEL_EXECUTOR_WORKERS=4

# -----------------------------------------------------------------------------
# Identity & role
# -----------------------------------------------------------------------------
# In production the upstream reverse proxy terminates SSO and injects
# identity headers; the backend reads them and the frontend gets identity
# from a /me endpoint.
#
# For local development the same shape is read from these env vars. Set
# USER_ROLES=admin to unlock the Admin section (Quality Metrics, Pattern
# Library, Evaluation, Run Comparison). Set USER_ROLES=user to demo the
# restricted reviewer experience.
#
# Leave both unset and use the in-app role switcher in the sidebar to flip
# between personas during a demo without restarting the server.
USER_EMAIL=demo@local
USER_ROLES=user

# -----------------------------------------------------------------------------
# Telemetry
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
